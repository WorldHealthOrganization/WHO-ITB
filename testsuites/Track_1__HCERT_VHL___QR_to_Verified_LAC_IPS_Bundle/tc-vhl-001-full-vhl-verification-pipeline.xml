<?xml version="1.0" encoding="UTF-8"?>
<testcase id="tc-vhl-001-full-vhl-verification-pipeline"
          xmlns="http://www.gitb.com/tdl/v1/"
          xmlns:gitb="http://www.gitb.com/core/v1/">
  <metadata>
    <gitb:name>tc-vhl-001 Full VHL verification pipeline</gitb:name>
    <gitb:version>1.0</gitb:version>
    <gitb:description>Track 1: HCERT VHL — QR to Verified LAC IPS Bundle</gitb:description>
  </metadata>

  <actors>
    <gitb:actor id="User" role="SUT"/>
    <gitb:actor id="HCertDecoder" role="SIMULATED"/>
    <gitb:actor id="VHLResponder" role="SIMULATED"/>
    <gitb:actor id="SmartHelper" role="SIMULATED"/>
    <gitb:actor id="FHIRValidator" role="SIMULATED"/>
  </actors>

  <variables>
    <var name="uploadedFile" type="binary"/>
    <var name="pinValue" type="string">
      <value>&quot;&quot;</value>
    </var>
    <var name="rawQRData" type="string"/>
    <var name="decodeHc1Body" type="string"/>
    <var name="coseVal" type="string"/>
    <var name="payloadVal" type="string"/>
    <var name="hcertVal" type="string"/>
    <var name="coseRaw" type="string"/>
    <var name="coseRawProtected" type="string"/>
    <var name="coseRawPayload" type="string"/>
    <var name="coseRawSignature" type="string"/>
    <var name="metaBody" type="string"/>
    <var name="verifyBody" type="string"/>
    <var name="sigValid" type="string"/>
    <var name="refBody" type="string"/>
    <var name="shlinkUrl" type="string"/>
    <var name="authBody" type="string"/>
    <var name="manifestVal" type="string"/>
    <var name="templateBody" type="string"/>
    <var name="fhirFound" type="string"/>
    <var name="fhirFetchError" type="string"/>
    <var name="firstResource" type="string"/>
    <var name="loadIgBody" type="string"/>
    <var name="conformBody" type="string"/>
    <var name="validationErrors" type="string"/>
    <var name="validationOutcome" type="string"/>
    <var name="dgFpBody" type="string"/>
    <var name="realErrors" type="string"/>
    <var name="lastRequest" type="map"/>
    <var name="HCertDecoderBase" type="string"/>
    <var name="VHLResponderBase" type="string"/>
    <var name="SmartHelperBase" type="string"/>
    <var name="FHIRValidatorBase" type="string"/>
    <var name="imgPart" type="map"/>
    <var name="sendParts" type="list[map]"/>
    <var name="reqHeaders" type="map"/>
    <var name="decodeHc1TplParams" type="map"/>
    <var name="decodeHc1Headers" type="map"/>
    <var name="metaTplParams" type="map"/>
    <var name="metaHeaders" type="map"/>
    <var name="verifyParams" type="map"/>
    <var name="verifyTpl" type="string"/>
    <var name="verifyHeaders" type="map"/>
    <var name="sigStatus" type="string"/>
    <var name="refTplParams" type="map"/>
    <var name="refHeaders" type="map"/>
    <var name="authParams" type="map"/>
    <var name="authTpl" type="string"/>
    <var name="authHeaders" type="map"/>
    <var name="tplParamsManifest" type="map"/>
    <var name="tplManifest" type="string"/>
    <var name="jsonHeaders" type="map"/>
    <var name="loadIgHeaders" type="map"/>
    <var name="loadIgTplParams" type="map"/>
    <var name="conformHeaders" type="map"/>
    <var name="conformTplParams" type="map"/>
    <var name="dgFpParams" type="map"/>
  </variables>

  <steps stopOnError="false">
    <assign to="HCertDecoderBase">&quot;http://hcert-validator:8080&quot;</assign>
    <assign to="VHLResponderBase">&quot;http://hcert-validator:8080&quot;</assign>
    <assign to="SmartHelperBase">&quot;http://smart-helper:8000&quot;</assign>
    <assign to="FHIRValidatorBase">&quot;http://fhir-validator:8080&quot;</assign>
    <interact id="userFileUpload" desc="Upload QR code image">
      <request desc="Upload a QRCode:" name="uploadedFile" inputType="UPLOAD" required="true">$uploadedFile</request>
    </interact>
    <assign to="imgPart{name}">&quot;image&quot;</assign>
    <assign to="imgPart{contentType}">&quot;image/png&quot;</assign>
    <assign to="imgPart{fileName}">&quot;upload.png&quot;</assign>
    <assign to="imgPart{content}">$uploadedFile</assign>
    <assign to="sendParts" append="true">$imgPart</assign>
    <assign to="reqHeaders{Accept}">&quot;application/json&quot;</assign>
    <send id="lastRequest" desc="Decode QR image" handler="HttpMessagingV2" from="User" to="HCertDecoder">
      <input name="uri">concat($HCertDecoderBase, &quot;/decode/image&quot;)</input>
      <input name="method">&quot;POST&quot;</input>
      <input name="parts">$sendParts</input>
      <input name="headers">$reqHeaders</input>
    </send>
    <interact id="enterPin" desc="Enter the PIN for retrieving the content" inputTitle="Authorize link">
      <request desc="Enter PIN:" required="false">$pinValue</request>
    </interact>
    <process handler="JsonPointerProcessor" operation="process" output="rawQRData">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/qr_data&quot;</input>
    </process>
    <assign to="decodeHc1TplParams{value}">$rawQRData</assign>
    <process handler="TemplateProcessor" operation="process" output="decodeHc1Body">
      <input name="syntax">&quot;freemarker&quot;</input>
      <input name="template">'{&quot;qr_data&quot;:&quot;${value?json_string}&quot;,&quot;include_raw&quot;:true}'</input>
      <input name="parameters">$decodeHc1TplParams</input>
    </process>
    <assign to="decodeHc1Headers{Content-Type}">&quot;application/json&quot;</assign>
    <assign to="decodeHc1Headers{Accept}">&quot;application/json&quot;</assign>
    <send id="lastRequest" desc="Decode HC1" handler="HttpMessagingV2" from="User" to="HCertDecoder">
      <input name="uri">concat($HCertDecoderBase, &quot;/decode/hcert&quot;)</input>
      <input name="method">&quot;POST&quot;</input>
      <input name="headers">$decodeHc1Headers</input>
      <input name="body">$decodeHc1Body</input>
    </send>
    <process handler="JsonPointerProcessor" operation="process" output="coseVal">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/cose&quot;</input>
    </process>
    <process handler="JsonPointerProcessor" operation="process" output="payloadVal">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/payload&quot;</input>
    </process>
    <process handler="JsonPointerProcessor" operation="process" output="hcertVal">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/hcert&quot;</input>
    </process>
    <process handler="JsonPointerProcessor" operation="process" output="coseRaw">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/cose/_raw&quot;</input>
    </process>
    <process handler="JsonPointerProcessor" operation="process" output="coseRawProtected">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/cose/_raw/protected_bstr&quot;</input>
    </process>
    <process handler="JsonPointerProcessor" operation="process" output="coseRawPayload">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/cose/_raw/payload_bstr&quot;</input>
    </process>
    <process handler="JsonPointerProcessor" operation="process" output="coseRawSignature">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/cose/_raw/signature&quot;</input>
    </process>
    <assign to="metaTplParams{cose}">$coseVal</assign>
    <assign to="metaTplParams{payload}">$payloadVal</assign>
    <process handler="TemplateProcessor" operation="process" output="metaBody">
      <input name="syntax">&quot;freemarker&quot;</input>
      <input name="template">'{&quot;cose&quot;:${cose},&quot;payload&quot;:${payload}}'</input>
      <input name="parameters">$metaTplParams</input>
    </process>
    <assign to="metaHeaders{Content-Type}">&quot;application/json&quot;</assign>
    <assign to="metaHeaders{Accept}">&quot;application/json&quot;</assign>
    <send id="lastRequest" desc="Extract metadata" handler="HttpMessagingV2" from="User" to="HCertDecoder">
      <input name="uri">concat($HCertDecoderBase, &quot;/extract/metadata&quot;)</input>
      <input name="method">&quot;POST&quot;</input>
      <input name="headers">$metaHeaders</input>
      <input name="body">$metaBody</input>
    </send>
    <assign to="verifyParams{cose_raw_protected}">$coseRawProtected</assign>
    <assign to="verifyParams{cose_raw_payload}">$coseRawPayload</assign>
    <assign to="verifyParams{cose_raw_signature}">$coseRawSignature</assign>
    <assign to="verifyParams{use_gdhcn}">&quot;true&quot;</assign>
    <assign to="verifyParams{gdhcn_env}">&quot;dev&quot;</assign>
    <assign to="verifyParams{participant}">&quot;-&quot;</assign>
    <assign to="verifyParams{usage}">&quot;DSC&quot;</assign>
    <assign to="verifyParams{verify_did_proof}">&quot;true&quot;</assign>
    <assign to="verifyParams{allow_unverified_trustlist}">&quot;true&quot;</assign>
    <assign to="verifyParams{allow_remote_contexts}">&quot;true&quot;</assign>
    <assign to="verifyParams{context_dir}">&quot;contexts&quot;</assign>
    <assign to="verifyTpl">'{&quot;cose_raw&quot;:{&quot;protected_bstr&quot;:&quot;${cose_raw_protected?json_string}&quot;,&quot;payload_bstr&quot;:&quot;${cose_raw_payload?json_string}&quot;,&quot;signature&quot;:&quot;${cose_raw_signature?json_string}&quot;},&quot;use_gdhcn&quot;:${use_gdhcn},&quot;gdhcn_env&quot;:&quot;${gdhcn_env}&quot;&lt;#if (domain!&quot;&quot;)?has_content&gt;,&quot;domain&quot;:&quot;${domain}&quot;&lt;/#if&gt;,&quot;participant&quot;:&quot;${participant}&quot;,&quot;usage&quot;:&quot;${usage}&quot;,&quot;verify_did_proof&quot;:${verify_did_proof},&quot;allow_unverified_trustlist&quot;:${allow_unverified_trustlist},&quot;allow_remote_contexts&quot;:${allow_remote_contexts},&quot;context_dir&quot;:&quot;${context_dir}&quot;}'</assign>
    <process handler="TemplateProcessor" operation="process" output="verifyBody">
      <input name="syntax">&quot;freemarker&quot;</input>
      <input name="template">$verifyTpl</input>
      <input name="parameters">$verifyParams</input>
    </process>
    <assign to="verifyHeaders{Content-Type}">&quot;application/json&quot;</assign>
    <send id="lastRequest" desc="Verify COSE signature" handler="HttpMessagingV2" from="User" to="HCertDecoder">
      <input name="uri">concat($HCertDecoderBase, &quot;/verify/signature&quot;)</input>
      <input name="method">&quot;POST&quot;</input>
      <input name="headers">$verifyHeaders</input>
      <input name="body">$verifyBody</input>
    </send>
    <assign to="sigStatus">if (empty($lastRequest{response}{status})) then &quot;0&quot; else $lastRequest{response}{status}</assign>
    <verify handler="NumberValidator" desc="Response status is 200">
      <input name="actualnumber">$sigStatus</input>
      <input name="expectednumber">&quot;200&quot;</input>
    </verify>
    <process handler="JsonPointerProcessor" operation="process" output="sigValid">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/valid&quot;</input>
    </process>
    <verify handler="StringValidator" desc="Equals">
      <input name="actualstring">$sigValid</input>
      <input name="expectedstring">&quot;true&quot;</input>
    </verify>
    <assign to="refTplParams{hcert}">$hcertVal</assign>
    <assign to="refTplParams{payload}">$payloadVal</assign>
    <process handler="TemplateProcessor" operation="process" output="refBody">
      <input name="syntax">&quot;freemarker&quot;</input>
      <input name="template">'{&quot;hcert&quot;:${hcert},&quot;payload&quot;:${payload}}'</input>
      <input name="parameters">$refTplParams</input>
    </process>
    <assign to="refHeaders{Content-Type}">&quot;application/json&quot;</assign>
    <assign to="refHeaders{Accept}">&quot;application/json&quot;</assign>
    <send id="lastRequest" desc="Extract SHL reference" handler="HttpMessagingV2" from="User" to="HCertDecoder">
      <input name="uri">concat($HCertDecoderBase, &quot;/extract/reference&quot;)</input>
      <input name="method">&quot;POST&quot;</input>
      <input name="headers">$refHeaders</input>
      <input name="body">$refBody</input>
    </send>
    <process handler="JsonPointerProcessor" operation="process" output="shlinkUrl">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/url&quot;</input>
    </process>
    <assign to="sigStatus">if (empty($lastRequest{response}{status})) then &quot;0&quot; else $lastRequest{response}{status}</assign>
    <verify handler="NumberValidator" desc="Response status is 200">
      <input name="actualnumber">$sigStatus</input>
      <input name="expectednumber">&quot;200&quot;</input>
    </verify>
    <assign to="authParams{url}">$shlinkUrl</assign>
    <assign to="authParams{pin}">$pinValue</assign>
    <assign to="authTpl">'{&quot;url&quot;:&quot;${url?string?replace(&quot;\\&quot;,&quot;\\\\&quot;) ?replace(&quot;\&quot;&quot;,&quot;\\\&quot;&quot;)}&quot;, &quot;pin&quot;:&quot;${pin?string?trim ?replace(&quot;\\&quot;,&quot;\\\\&quot;) ?replace(&quot;\&quot;&quot;,&quot;\\\&quot;&quot;)}&quot;}'</assign>
    <process handler="TemplateProcessor" operation="process" output="authBody">
      <input name="syntax">&quot;freemarker&quot;</input>
      <input name="template">$authTpl</input>
      <input name="parameters">$authParams</input>
    </process>
    <assign to="authHeaders{Content-Type}">&quot;application/json&quot;</assign>
    <send id="lastRequest" desc="Authorize short link" handler="HttpMessagingV2" from="User" to="VHLResponder">
      <input name="uri">concat($VHLResponderBase, &quot;/shlink/authorize&quot;)</input>
      <input name="method">&quot;POST&quot;</input>
      <input name="headers">$authHeaders</input>
      <input name="body">$authBody</input>
    </send>
    <assign to="sigStatus">if (empty($lastRequest{response}{status})) then &quot;0&quot; else $lastRequest{response}{status}</assign>
    <verify handler="NumberValidator" desc="Response status is 200">
      <input name="actualnumber">$sigStatus</input>
      <input name="expectednumber">&quot;200&quot;</input>
    </verify>
    <process handler="JsonPointerProcessor" operation="process" output="manifestVal">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/manifest&quot;</input>
    </process>
    <assign to="tplParamsManifest{manifest}">$manifestVal</assign>
    <assign to="tplManifest">'{&quot;manifest&quot;: ${manifest?has_content?then(manifest, &quot;null&quot;)}}'</assign>
    <process handler="TemplateProcessor" operation="process" output="templateBody">
      <input name="syntax">&quot;freemarker&quot;</input>
      <input name="template">$tplManifest</input>
      <input name="parameters">$tplParamsManifest</input>
    </process>
    <assign to="jsonHeaders{Content-Type}">&quot;application/json&quot;</assign>
    <assign to="jsonHeaders{Accept}">&quot;application/fhir+json&quot;</assign>
    <send id="lastRequest" desc="Fetch FHIR via manifest" handler="HttpMessagingV2" from="User" to="VHLResponder">
      <input name="uri">concat($VHLResponderBase, &quot;/shlink/fetch-fhir&quot;)</input>
      <input name="method">&quot;POST&quot;</input>
      <input name="headers">$jsonHeaders</input>
      <input name="body">$templateBody</input>
    </send>
    <process handler="JsonPointerProcessor" operation="process" output="fhirFound">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/found&quot;</input>
    </process>
    <process handler="JsonPointerProcessor" operation="process" output="fhirFetchError">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/errors/0&quot;</input>
    </process>
    <log>concat(&quot;fetch-fhir: found=&quot;, $fhirFound, &quot; firstError=&quot;, $fhirFetchError)</log>
    <verify handler="StringValidator" desc="IPS bundle retrieved from SHL manifest (found=true; false = the manifest file URL could not be dereferenced — see log for the fetch error, e.g. the IPS host returning HTTP 500)">
      <input name="actualstring">$fhirFound</input>
      <input name="expectedstring">&quot;true&quot;</input>
    </verify>
    <assign to="sigStatus">if (empty($lastRequest{response}{status})) then &quot;0&quot; else $lastRequest{response}{status}</assign>
    <verify handler="NumberValidator" desc="Response status is 200">
      <input name="actualnumber">$sigStatus</input>
      <input name="expectednumber">&quot;200&quot;</input>
    </verify>
    <process handler="JsonPointerProcessor" operation="process" output="firstResource">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/fhir/0/resource&quot;</input>
    </process>
    <assign to="loadIgHeaders{Content-Type}">&quot;application/json&quot;</assign>
    <assign to="loadIgHeaders{Accept}">&quot;application/json&quot;</assign>
    <assign to="loadIgTplParams{ig}">&quot;https://ig.racsel.org&quot;</assign>
    <process handler="TemplateProcessor" operation="process" output="loadIgBody">
      <input name="syntax">&quot;freemarker&quot;</input>
      <input name="template">'{ &quot;operation&quot;: &quot;loadIG&quot;, &quot;input&quot;: [ { &quot;name&quot;: &quot;ig&quot;, &quot;value&quot;: &quot;${ig?json_string}&quot;, &quot;embeddingMethod&quot;: &quot;STRING&quot; } ] }'</input>
      <input name="parameters">$loadIgTplParams</input>
    </process>
    <send id="lastRequest" desc="Load IG https://ig.racsel.org" handler="HttpMessagingV2" from="User" to="FHIRValidator">
      <input name="uri">concat($FHIRValidatorBase, &quot;/itb/igManager/process&quot;)</input>
      <input name="method">&quot;POST&quot;</input>
      <input name="headers">$loadIgHeaders</input>
      <input name="body">$loadIgBody</input>
    </send>
    <assign to="sigStatus">if (empty($lastRequest{response}{status})) then &quot;0&quot; else $lastRequest{response}{status}</assign>
    <verify handler="NumberValidator" desc="Response status is 200">
      <input name="actualnumber">$sigStatus</input>
      <input name="expectednumber">&quot;200&quot;</input>
    </verify>
    <assign to="conformHeaders{Content-Type}">&quot;application/json&quot;</assign>
    <assign to="conformHeaders{Accept}">&quot;application/json&quot;</assign>
    <assign to="conformTplParams{resource}">$firstResource</assign>
    <assign to="conformTplParams{profile}">&quot;http://racsel.org/StructureDefinition/LACBundleIPS&quot;</assign>
    <process handler="TemplateProcessor" operation="process" output="conformBody">
      <input name="syntax">&quot;freemarker&quot;</input>
      <input name="template">'{ &quot;input&quot;: [ { &quot;name&quot;: &quot;contentToValidate&quot;, &quot;value&quot;: &quot;${resource?json_string}&quot;, &quot;embeddingMethod&quot;: &quot;STRING&quot; }, { &quot;name&quot;: &quot;profiles&quot;, &quot;value&quot;: &quot;${profile?json_string}&quot;, &quot;embeddingMethod&quot;: &quot;STRING&quot; } ] }'</input>
      <input name="parameters">$conformTplParams</input>
    </process>
    <send id="lastRequest" desc="Validate firstResource conforms to http://racsel.org/StructureDefinition/LACBundleIPS (downgrading slicing errors)" handler="HttpMessagingV2" from="User">
      <input name="uri">concat($FHIRValidatorBase, &quot;/itb/fhir/validate&quot;)</input>
      <input name="method">&quot;POST&quot;</input>
      <input name="headers">$conformHeaders</input>
      <input name="body">$conformBody</input>
    </send>
    <process handler="JsonPointerProcessor" operation="process" output="validationErrors">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/report/context/0/value&quot;</input>
    </process>
    <process handler="JsonPointerProcessor" operation="process" output="validationOutcome">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/report/context/4/value&quot;</input>
    </process>
    <assign to="dgFpParams{resource}">$validationOutcome</assign>
    <assign to="dgFpParams{expression}">&quot;issue.where(severity = 'error').count() - issue.where(severity = 'error' and details.text.contains('matching slice is required')).count()&quot;</assign>
    <process handler="TemplateProcessor" operation="process" output="dgFpBody">
      <input name="syntax">&quot;freemarker&quot;</input>
      <input name="template">'{ &quot;operation&quot;: &quot;evaluate&quot;, &quot;input&quot;: [ { &quot;name&quot;: &quot;content&quot;, &quot;value&quot;: &quot;${resource?json_string}&quot;, &quot;embeddingMethod&quot;: &quot;STRING&quot; }, { &quot;name&quot;: &quot;expression&quot;, &quot;value&quot;: &quot;${expression?json_string}&quot;, &quot;embeddingMethod&quot;: &quot;STRING&quot; } ] }'</input>
      <input name="parameters">$dgFpParams</input>
    </process>
    <send id="lastRequest" desc="Count real (non-downgraded) errors via FHIRPath" handler="HttpMessagingV2" from="User">
      <input name="uri">concat($FHIRValidatorBase, &quot;/itb/fhirPath/process&quot;)</input>
      <input name="method">&quot;POST&quot;</input>
      <input name="headers">$conformHeaders</input>
      <input name="body">$dgFpBody</input>
    </send>
    <process handler="JsonPointerProcessor" operation="process" output="realErrors">
      <input name="content">$lastRequest{response}{body}</input>
      <input name="pointer">&quot;/output/0/value&quot;</input>
    </process>
    <log>concat(&quot;conforms (downgrading): &quot;, $validationErrors, &quot; total errors, &quot;, $realErrors, &quot; real after downgrading (matching issues stay in the report, not counted)&quot;)</log>
    <verify handler="StringValidator" desc="firstResource conforms to http://racsel.org/StructureDefinition/LACBundleIPS downgrading slicing errors (real errors must be 0)">
      <input name="actualstring">$realErrors</input>
      <input name="expectedstring">&quot;0&quot;</input>
    </verify>
  </steps>

  <output>
    <success>
      <default>"Test case completed successfully."</default>
    </success>
    <failure>
      <default>"Test case failed. Check step reports and logs."</default>
    </failure>
  </output>
</testcase>