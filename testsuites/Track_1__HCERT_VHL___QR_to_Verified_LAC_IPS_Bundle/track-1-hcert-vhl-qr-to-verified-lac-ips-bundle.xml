<?xml version="1.0" encoding="UTF-8"?>
<testsuite id="track-1-hcert-vhl-qr-to-verified-lac-ips-bundle"
           xmlns="http://www.gitb.com/tdl/v1/"
           xmlns:gitb="http://www.gitb.com/core/v1/">
  <metadata>
    <gitb:name>Track 1: HCERT VHL — QR to Verified LAC IPS Bundle</gitb:name>
    <gitb:version>1.0</gitb:version>
    <gitb:description>Semantic-equivalent Gherkin for the hand-written test-case-vhl.xml: QR upload → HC1 decode → metadata extract → COSE signature check (DEV) → SHL reference extract → SHL authorize (PIN) → FHIR fetch via manifest → LacPass IG install → HAPI $validate against the LAC IPS Bundle profile.</gitb:description>
  </metadata>

  <actors>
    <gitb:actor id="User">
      <gitb:name>User</gitb:name>
    </gitb:actor>
    <gitb:actor id="HCertDecoder">
      <gitb:name>HCertDecoder</gitb:name>
      <gitb:desc>Endpoint: http://hcert-validator:8080</gitb:desc>
    </gitb:actor>
    <gitb:actor id="VHLResponder">
      <gitb:name>VHLResponder</gitb:name>
      <gitb:desc>Endpoint: http://hcert-validator:8080</gitb:desc>
    </gitb:actor>
    <gitb:actor id="SmartHelper">
      <gitb:name>SmartHelper</gitb:name>
      <gitb:desc>Endpoint: http://smart-helper:8000</gitb:desc>
    </gitb:actor>
    <gitb:actor id="FHIRValidator">
      <gitb:name>FHIRValidator</gitb:name>
      <gitb:desc>Endpoint: http://fhir-validator:8080</gitb:desc>
    </gitb:actor>
  </actors>

  <testcase id="tc-vhl-001-full-vhl-verification-pipeline"/>

</testsuite>