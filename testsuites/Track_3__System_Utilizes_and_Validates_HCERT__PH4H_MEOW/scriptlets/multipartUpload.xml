<?xml version="1.0" encoding="UTF-8"?>
<scriptlet id="multipartUpload"
            xmlns="http://www.gitb.com/tdl/v1/"
            xmlns:gitb="http://www.gitb.com/core/v1/">
  <!--
    Reusable scriptlet: Build a multipart POST with a single file part and send it.
    Inputs:
      uri         — target URI
      file        — binary content to upload
      partName    — form field name (e.g. "image")
      contentType — MIME type (e.g. "image/png")
      fileName    — filename for the part (e.g. "upload.png")
      desc        — step description
    The send result "response" is available via the call's output attribute.
  -->
  <params>
    <var name="uri" type="string"/>
    <var name="file" type="binary"/>
    <var name="partName" type="string"/>
    <var name="contentType" type="string"/>
    <var name="fileName" type="string"/>
    <var name="desc" type="string"/>
  </params>
  <steps>
    <!-- Build the part map -->
    <assign to="part{name}">$partName</assign>
    <assign to="part{contentType}">$contentType</assign>
    <assign to="part{fileName}">$fileName</assign>
    <assign to="part{content}">$file</assign>
    <!-- Build parts list -->
    <assign to="parts" append="true">$part</assign>
    <!-- Headers -->
    <assign to="hdrs{Accept}">"application/json"</assign>
    <!-- Send multipart POST -->
    <send id="response" desc="$desc" handler="HttpMessagingV2">
      <input name="uri">$uri</input>
      <input name="method">"POST"</input>
      <input name="parts">$parts</input>
      <input name="headers">$hdrs</input>
    </send>
  </steps>
</scriptlet>
